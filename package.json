{
  "name": "@afe1/vite-plugin-app-loading",
  "version": "0.1.2",
  "description": "Inject a loading overlay into Vite HTML and expose a manual remover for app startup.",
  "type": "module",
  "packageManager": "pnpm@10.31.0",
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "scripts": {
    "build": "tsdown",
    "playground:dev": "pnpm run build && vite --config playground/vite.config.ts --host 127.0.0.1 --port 5173",
    "typecheck": "tsc --noEmit",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "pnpm run build && changeset publish"
  },
  "keywords": [
    "vite",
    "vite-plugin",
    "loading",
    "app-loading",
    "html-injection"
  ],
  "peerDependencies": {
    "vite": ">=4.0.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@types/node": "^20.0.0",
    "tsdown": "^0.22.1",
    "typescript": "^5.0.0",
    "vite": "^5.0.0"
  },
  "license": "MIT"
}
